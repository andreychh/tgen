package api

import (
	"bytes"
	"context"
	"encoding/json"
	"fmt"
	"io"
	"net/http"
)

// Envelope represents the standard Telegram Bot API JSON response envelope.
type Envelope struct {
	Ok          bool                `json:"ok"`
	Result      json.RawMessage     `json:"result,omitempty"`
	ErrorCode   *int                `json:"error_code,omitempty"`
	Description *string             `json:"description,omitempty"`
	Parameters  *ResponseParameters `json:"parameters,omitempty"`
}

// Connection executes Telegram Bot API methods over a transport.
type Connection interface {
	// Do sends method with request as the JSON body and decodes the result into
	// response. It returns an error if the transport fails or the API reports a
	// failure.
	Do(ctx context.Context, method Method, request, response any) error
}

// HTTPConnection implements Connection over HTTP using the Telegram Bot API
// endpoint.
type HTTPConnection struct {
	client *http.Client
	token  string
}

// NewHTTPConnection creates an HTTPConnection from an HTTP client and a bot
// token.
func NewHTTPConnection(client *http.Client, token string) HTTPConnection {
	return HTTPConnection{client: client, token: token}
}

// Do marshals request as JSON, sends a POST to the Telegram API, and decodes
// the result into response. It returns an error if the request cannot be built,
// the transport fails, the API reports a failure, or the result cannot be
// decoded.
func (c HTTPConnection) Do(ctx context.Context, method Method, request, response any) error {
	body, err := json.Marshal(request)
	if err != nil {
		return fmt.Errorf("marshaling request: %w", err)
	}
	req, err := c.request(ctx, c.url(method), bytes.NewReader(body))
	if err != nil {
		return fmt.Errorf("creating request: %w", err)
	}
	resp, err := c.client.Do(req)
	if err != nil {
		return fmt.Errorf("sending request: %w", err)
	}
	defer func() { _ = resp.Body.Close() }()
	var envelope Envelope
	if err = json.NewDecoder(resp.Body).Decode(&envelope); err != nil {
		return fmt.Errorf("decoding envelope: %w", err)
	}
	if !envelope.Ok {
		desc := "<no description>"
		if envelope.Description != nil {
			desc = *envelope.Description
		}
		return fmt.Errorf("telegram error: %s", desc)
	}
	if err = json.Unmarshal(envelope.Result, response); err != nil {
		return fmt.Errorf("decoding result: %w", err)
	}
	return nil
}

func (c HTTPConnection) request(
	ctx context.Context,
	url string,
	body io.Reader,
) (*http.Request, error) {
	req, err := http.NewRequestWithContext(ctx, http.MethodPost, url, body)
	if err != nil {
		return nil, err
	}
	req.Header.Set("Content-Type", "application/json")
	return req, nil
}

func (c HTTPConnection) url(method Method) string {
	return fmt.Sprintf("https://api.telegram.org/bot%s/%s", c.token, method)
}
