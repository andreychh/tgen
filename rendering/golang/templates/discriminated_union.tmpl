{{- end}}
    return nil, errors.New("{{.Name.AsString}}: internal error")
}

func (u *{{.Name.AsString}}) UnmarshalJSON(data []byte) error {
    var disc struct {
        Key string `json:"{{.DiscriminatorKey.AsString}}"`
    }
    if err := json.Unmarshal(data, &disc); err != nil {
        return err
    }
    switch disc.Key {
{{- range $variants}} {{/*gotype: github.com/andreychh/tgen/rendering/golang.DiscriminatedVariant*/}}
