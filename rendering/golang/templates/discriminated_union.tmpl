    }
    if err := json.Unmarshal(data, &disc); err != nil {
        return nil, err
    }
    switch disc.Key {
    {{- range .Variants | discriminated_variants}} {{/*gotype: github.com/andreychh/tgen/rendering/golang.DiscriminatedVariant*/}}
