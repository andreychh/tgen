        var v {{.Name.AsString}}
        if err := json.Unmarshal(data, &v); err != nil {
          return nil, err
        }
        return v, nil
{{- end}}
    default:
      return nil, fmt.Errorf("unknown {{.Name.AsString}}: %q", disc.Key)
    }
}
