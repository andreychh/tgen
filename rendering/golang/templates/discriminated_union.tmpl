{{- define "discriminated_union"}} {{/*gotype: github.com/andreychh/tgen/rendering/golang.DiscriminatedUnion*/}}
{{- $name := .Name.AsString}}
{{.Doc.AsString}}
//sumtype:decl
type {{$name}} interface{ sealed{{$name}}() }
{{range .Variants | discriminated_variants}}
func (v {{.Name.AsString}}) sealed{{$name}}() {}
{{- end}}
{{- if ne $name "InlineQueryResult"}}

func unmarshal{{$name}}(data []byte) ({{$name}}, error) {
	var disc struct {
		Key string `json:"{{.DiscriminatorKey.AsString}}"`
	}
	if err := json.Unmarshal(data, &disc); err != nil {
		return nil, err
	}
	switch disc.Key {
{{- range .Variants | discriminated_variants}}
{{- $variantName := .Name.AsString}}
	case "{{.DiscriminatorValue.AsString}}":
		var v {{$variantName}}
		if err := json.Unmarshal(data, &v); err != nil {
			return nil, err
		}
		return v, nil
{{- end}}
	default:
		return nil, fmt.Errorf("unknown {{$name}}: %q", disc.Key)
	}
}
{{- end}}

{{- end}}
