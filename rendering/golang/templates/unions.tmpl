	}
	if len(fields) == 0 {
		return nil, fmt.Errorf("%s: no fields set (expected exactly one)", typeName)
	}
	if len(fields) > 1 {
		return nil, fmt.Errorf("%s: multiple fields set (%s)", typeName, strings.Join(fields, ", "))
	}
	if file != nil {
		return json.Marshal(file)
	}
	return json.Marshal(fileID)
}

func unmarshalFileOrID(data []byte, file **InputFile, fileID **string) error {
	var valueFileID string
	decoder := json.NewDecoder(bytes.NewReader(data))
	decoder.DisallowUnknownFields()
	if decoder.Decode(&valueFileID) == nil {
		*fileID = &valueFileID
		return nil
	}
	var valueFile InputFile
	decoder = json.NewDecoder(bytes.NewReader(data))
	decoder.DisallowUnknownFields()
	if decoder.Decode(&valueFile) == nil {
		*file = &valueFile
		return nil
	}
	return fmt.Errorf("expected InputFile or string, got %.50q", string(data))
}

