func (u MaybeInaccessibleMessage) MarshalJSON() ([]byte, error) {
	var fields []string
	if u.Message != nil {
		fields = append(fields, "Message")
	}
	if u.InaccessibleMessage != nil {
		fields = append(fields, "InaccessibleMessage")
	}
	if len(fields) == 0 {
		return nil, errors.New("MaybeInaccessibleMessage: no fields set (expected exactly one)")
	}
	if len(fields) > 1 {
		return nil, fmt.Errorf("MaybeInaccessibleMessage: multiple fields set (%s)", strings.Join(fields, ", "))
	}
	if u.Message != nil {
		return json.Marshal(u.Message)
	}
	if u.InaccessibleMessage != nil {
		return json.Marshal(u.InaccessibleMessage)
	}
	return nil, errors.New("MaybeInaccessibleMessage: internal error")
}

func (u *MaybeInaccessibleMessage) UnmarshalJSON(data []byte) error {
	var disc struct {
		Key int64 `json:"date"`
	}
	if err := json.Unmarshal(data, &disc); err != nil {
		return err
	}
	switch disc.Key {
	case 0:
		var v InaccessibleMessage
		if err := json.Unmarshal(data, &v); err != nil {
			return err
		}
		u.InaccessibleMessage = &v
	default:
		var v Message
		if err := json.Unmarshal(data, &v); err != nil {
			return err
		}
		u.Message = &v
	}
	return nil
}

