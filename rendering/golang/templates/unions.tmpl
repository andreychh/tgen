func marshalMessageOrOk(typeName string, msg *Message, ok *bool) ([]byte, error) {
	var fields []string
	if msg != nil {
		fields = append(fields, "Message")
	}
	if ok != nil {
		fields = append(fields, "Ok")
	}
	if len(fields) == 0 {
		return nil, fmt.Errorf("%s: no fields set (expected exactly one)", typeName)
	}
	if len(fields) > 1 {
		return nil, fmt.Errorf("%s: multiple fields set (%s)", typeName, strings.Join(fields, ", "))
	}
	if msg != nil {
		return json.Marshal(msg)
	}
	return json.Marshal(ok)
}

func unmarshalMessageOrOk(data []byte, msg **Message, ok **bool) error {
	var valueMessage Message
	decoder := json.NewDecoder(bytes.NewReader(data))
	decoder.DisallowUnknownFields()
	if decoder.Decode(&valueMessage) == nil {
		*msg = &valueMessage
		return nil
	}
	var valueOk bool
	decoder = json.NewDecoder(bytes.NewReader(data))
	decoder.DisallowUnknownFields()
	if decoder.Decode(&valueOk) == nil {
		*ok = &valueOk
		return nil
	}
	return fmt.Errorf("unexpected value %.50q", string(data))
}

