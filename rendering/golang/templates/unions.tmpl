	ChatID          *int64
	ChannelUsername *string
}

func (u FromChatID) MarshalJSON() ([]byte, error) {
	var fields []string
	if u.ChatID != nil {
		fields = append(fields, "ChatID")
	}
	if u.ChannelUsername != nil {
		fields = append(fields, "ChannelUsername")
	}
	if len(fields) == 0 {
		return nil, errors.New("FromChatID: no fields set (expected exactly one)")
	}
	if len(fields) > 1 {
		return nil, fmt.Errorf("FromChatID: multiple fields set (%s)", strings.Join(fields, ", "))
	}
	if u.ChatID != nil {
		return json.Marshal(u.ChatID)
	}
	return json.Marshal(u.ChannelUsername)
}

func (u *FromChatID) UnmarshalJSON(data []byte) error {
	var decoder *json.Decoder
	var valueChatID int64
	decoder = json.NewDecoder(bytes.NewReader(data))
	decoder.DisallowUnknownFields()
	if decoder.Decode(&valueChatID) == nil {
		u.ChatID = &valueChatID
		return nil
	}
	var valueChannelUsername string
	decoder = json.NewDecoder(bytes.NewReader(data))
	decoder.DisallowUnknownFields()
	if decoder.Decode(&valueChannelUsername) == nil {
		u.ChannelUsername = &valueChannelUsername
		return nil
	}
	return fmt.Errorf("FromChatID: unexpected value %.50q", string(data))
}

