{{- define "method_fields"}} {{/*gotype: github.com/andreychh/tgen/targets/python.Method*/}}
{{- range .Fields | fields}} {{/*gotype: github.com/andreychh/tgen/targets/python.Field*/}}
    {{.Name}}: {{.Annotation}}
    {{.Doc}}
{{- end}}
{{- end}}

{{- define "method"}} {{/*gotype: github.com/andreychh/tgen/targets/python.Method*/}}
{{- $name := .Name}}
{{- $ret := .ReturnType.Value}}
class {{$name}}Method(BaseModel):
    {{.Doc}}
{{template "method_fields" .}}

    def call(self, conn: Connection) -> {{$ret}}:
        payload = MultipartPayload()
{{- range .Fields | fields}}
{{- if .Optional}}
        if self.{{.Name}} is not None:
            {{.Part}}.write(payload, "{{.Key}}")
{{- else}}
        {{.Part}}.write(payload, "{{.Key}}")
{{- end}}
{{- end}}
        return conn.do(Method.{{$name}}, payload, TypeAdapter({{$ret}}))
{{- end}}
