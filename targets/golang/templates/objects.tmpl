// ID represents a numeric Telegram chat or user identifier.
type ID int64

func (i ID) Write(p *MultipartPayload, key string) error {
	return NewInt64Part(i).Write(p, key)
}

// Username represents a Telegram username.
type Username string

func (u Username) Write(p *MultipartPayload, key string) error {
	return NewStringPart(u).Write(p, key)
}

// True represents the boolean true value in Telegram API responses.
type True bool

// FileID represents a Telegram file identifier.
type FileID string

func (i FileID) Write(p *MultipartPayload, key string) error {
	return NewStringPart(i).Write(p, key)
}

// Upload represents a file to be uploaded by providing its name and reader.
type Upload struct {
	Name   string
	Reader io.Reader
}

func (u Upload) Write(p *MultipartPayload, key string) error {
	return p.File(key, u.Name, u.Reader)
}

