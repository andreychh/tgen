{{- define "method"}} {{/*gotype: github.com/andreychh/tgen/targets/golang.Method*/}}
{{- $name := .Name.AsString}}
{{- $ret := .ReturnType}}
{{- $isUnion := $ret.IsUnion}}
{{- $depth := $ret.Depth}}
{{.Doc.AsString}}
type {{$name}}Method struct {
{{- range .Fields | fields}} {{/*gotype: github.com/andreychh/tgen/targets/golang.Field*/}}
    {{.Doc.AsString}}
    {{.Name.AsString}} {{.Type.AsString}} {{.Tag.AsString}}
{{- end}}
}

{{- if not .IsMultipart}}
func (m {{$name}}Method) Call(ctx context.Context, conn Connection) ({{$ret.AsString}}, error) {
	data, err := json.Marshal(m)
	if err != nil {
		return {{$ret.Zero}}, err
	}
{{- if and $isUnion (eq $depth 1)}}
	var resp []json.RawMessage
	if err := conn.Do(ctx, Method{{$name}}, bytes.NewReader(data), "application/json", &resp); err != nil {
		return {{$ret.Zero}}, fmt.Errorf("%s: %w", Method{{$name}}, err)
	}
	result := make([]{{$ret.Name}}, len(resp))
	for i, r := range resp {
		u, err := unmarshal{{$ret.Name}}(r)
		if err != nil {
			return {{$ret.Zero}}, err
		}
		result[i] = u
	}
	return result, nil
{{- else if $isUnion}}
	var resp json.RawMessage
	if err := conn.Do(ctx, Method{{$name}}, bytes.NewReader(data), "application/json", &resp); err != nil {
		return {{$ret.Zero}}, fmt.Errorf("%s: %w", Method{{$name}}, err)
	}
	result, err := unmarshal{{$ret.Name}}(resp)
	if err != nil {
		return {{$ret.Zero}}, err
	}
	return result, nil
{{- else}}
	var resp {{$ret.AsString}}
	if err := conn.Do(ctx, Method{{$name}}, bytes.NewReader(data), "application/json", &resp); err != nil {
		return {{$ret.Zero}}, fmt.Errorf("%s: %w", Method{{$name}}, err)
	}
	return resp, nil
{{- end}}
}
{{- else}}
func (m {{$name}}Method) Call(ctx context.Context, conn Connection) ({{$ret.AsString}}, error) {
	form := NewEmptyMultipartForm()
{{- range .Fields | fields}} {{/*gotype: github.com/andreychh/tgen/targets/golang.Field*/}}
{{- if .Optional }}
	if m.{{.Name.AsString}} != nil {
{{- if eq .Type.Depth 1}}
		if err := NewPrimitive(m.{{.Name.AsString}}).FillForm(form, "{{.Key}}"); err != nil {
			return {{$ret.Zero}}, err
		}
{{- else if .Type.IsPrimitive }}
		if err := NewPrimitive(*m.{{.Name.AsString}}).FillForm(form, "{{.Key}}"); err != nil {
			return {{$ret.Zero}}, err
		}
{{- else if .Type.IsUnion }}
		if err := m.{{.Name.AsString}}.FillForm(form, "{{.Key}}"); err != nil {
			return {{$ret.Zero}}, err
		}
{{- else}}
		if err := (*m.{{.Name.AsString}}).FillForm(form, "{{.Key}}"); err != nil {
			return {{$ret.Zero}}, err
		}
{{- end}}
	}
{{- else}}
{{- if or .Type.IsPrimitive (eq .Type.Depth 1) }}
	if err := NewPrimitive(m.{{.Name.AsString}}).FillForm(form, "{{.Key}}"); err != nil {
		return {{$ret.Zero}}, err
	}
{{- else}}
	if err := m.{{.Name.AsString}}.FillForm(form, "{{.Key}}"); err != nil {
		return {{$ret.Zero}}, err
	}
{{- end}}
{{- end}}
{{- end}}
	body, ct, err := form.Seal()
	if err != nil {
		return {{$ret.Zero}}, err
	}
{{- if and $isUnion (eq $depth 1)}}
	var resp []json.RawMessage
	if err := conn.Do(ctx, Method{{$name}}, body, ct, &resp); err != nil {
		return {{$ret.Zero}}, fmt.Errorf("%s: %w", Method{{$name}}, err)
	}
	result := make([]{{$ret.Name}}, len(resp))
	for i, r := range resp {
		u, err := unmarshal{{$ret.Name}}(r)
		if err != nil {
			return {{$ret.Zero}}, err
		}
		result[i] = u
	}
	return result, nil
{{- else if $isUnion}}
	var resp json.RawMessage
	if err := conn.Do(ctx, Method{{$name}}, body, ct, &resp); err != nil {
		return {{$ret.Zero}}, fmt.Errorf("%s: %w", Method{{$name}}, err)
	}
	result, err := unmarshal{{$ret.Name}}(resp)
	if err != nil {
		return {{$ret.Zero}}, err
	}
	return result, nil
{{- else}}
	var resp {{$ret.AsString}}
	if err := conn.Do(ctx, Method{{$name}}, body, ct, &resp); err != nil {
		return {{$ret.Zero}}, fmt.Errorf("%s: %w", Method{{$name}}, err)
	}
	return resp, nil
{{- end}}
}
{{- end}}
{{- end}}
