{{- define "object"}} {{/*gotype: github.com/andreychh/tgen/targets/golang.Object*/}}
{{.Doc.Value}}
type {{.Name.Value}} struct {
{{- range .Fields | fields}} {{/*gotype: github.com/andreychh/tgen/targets/golang.Field*/}}
    {{.Doc.Value}}
    {{.Name.Value}} {{.Type.Value}} {{.Tag.Value}}
{{- end}}
}

{{- template "unmarshal_object" .}}

{{- if .HasInputFile}}
func (o {{.Name.Value}}) JSON(p *MultipartPayload) ([]byte, error) {
	type Alias {{.Name.Value}}
{{- range .Fields | fields}}
{{- if .IsInputFile}}
{{- if .Optional}}
	var {{.Key}} *string
	if o.{{.Name.Value}} != nil {
		ref, err := o.{{.Name.Value}}.Attach(p)
		if err != nil {
			return nil, err
		}
		{{.Key}} = &ref
	}
{{- else}}
	{{.Key}}, err := o.{{.Name.Value}}.Attach(p)
	if err != nil {
		return nil, err
	}
{{- end}}
{{- end}}
{{- end}}
	return json.Marshal(struct {
{{- range .Fields | fields}}
{{- if .IsInputFile}}
{{- if .Optional}}
		{{.Name.Value}} *string {{.Tag.Value}}
{{- else}}
		{{.Name.Value}} string {{.Tag.Value}}
{{- end}}
{{- end}}
{{- end}}
		Alias
	}{
{{- range .Fields | fields}}
{{- if .IsInputFile}}
		{{.Name.Value}}: {{.Key}},
{{- end}}
{{- end}}
		Alias: Alias(o),
	})
}
{{- else}}

func (o {{.Name.Value}}) JSON(_ *MultipartPayload) ([]byte, error) {
	return json.Marshal(o)
}
{{- end}}

func (o {{.Name.Value}}) Write(p *MultipartPayload, key string) error {
	data, err := o.JSON(p)
	if err != nil {
		return err
	}
	return p.Text(key, string(data))
}
{{- end}}