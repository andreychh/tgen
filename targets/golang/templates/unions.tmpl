// This object describes a message that can be inaccessible to the bot.
//
// See https://core.telegram.org/bots/api#maybeinaccessiblemessage
//sumtype:decl
type MaybeInaccessibleMessage interface{ sealedMaybeInaccessibleMessage() }

func (v Message) sealedMaybeInaccessibleMessage()             {}
func (v InaccessibleMessage) sealedMaybeInaccessibleMessage() {}

func unmarshalMaybeInaccessibleMessage(data []byte) (MaybeInaccessibleMessage, error) {
	var disc struct {
		Key int64 `json:"date"`
	}
	if err := json.Unmarshal(data, &disc); err != nil {
		return nil, fmt.Errorf("unmarshaling discriminator for MaybeInaccessibleMessage: %w", err)
	}
	switch disc.Key {
	case 0:
		var v InaccessibleMessage
		if err := json.Unmarshal(data, &v); err != nil {
			return nil, fmt.Errorf("unmarshaling InaccessibleMessage: %w", err)
		}
		return v, nil
	default:
		var v Message
		if err := json.Unmarshal(data, &v); err != nil {
			return nil, fmt.Errorf("unmarshaling Message: %w", err)
		}
		return v, nil
	}
}

