// RichText represents a rich formatted text. It is either plain text
// (RichTextPlain), a nested array of RichText (RichTextSequence), or one of the
// named RichText* formatting types.
//
// See https://core.telegram.org/bots/api#richtext
//sumtype:decl
type RichText interface{ part; formJSON; sealedRichText() }

// RichTextPlain represents the plain-text variant of a RichText value.
type RichTextPlain string

func (v RichTextPlain) sealedRichText() {}

func (v RichTextPlain) write(p *multipartPayload, key string) error {
	return newStringPart(v).write(p, key)
}

func (v RichTextPlain) json(_ *multipartPayload) ([]byte, error) {
	return json.Marshal(string(v))
}

// RichTextSequence represents the nested-array variant of a RichText value.
type RichTextSequence []RichText

func (v RichTextSequence) sealedRichText() {}

func (v RichTextSequence) write(p *multipartPayload, key string) error {
	return newObjectSlicePart([]RichText(v)).write(p, key)
}

func (v RichTextSequence) json(p *multipartPayload) ([]byte, error) {
	parts := make([]json.RawMessage, len(v))
	for i, el := range v {
		data, err := el.json(p)
		if err != nil {
			return nil, err
		}
		parts[i] = data
	}
	return json.Marshal(parts)
}

