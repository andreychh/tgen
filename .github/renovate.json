{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "group:allNonMajor"
  ],
  "minimumReleaseAge": "3 days",
  "rebaseWhen": "behind-base-branch",
  "semanticCommits": "enabled",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major"
      ],
      "schedule": [
        "every weekend"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "schedule": [
        "every weekend"
      ],
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "uses: jdx/mise-action@.*\\n\\s+with:\\n\\s+version: (?<currentValue>.*)"
      ],
      "depNameTemplate": "jdx/mise",
      "datasourceTemplate": "github-releases"
    }
  ]
}
