{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "ignorePaths": [
    "stands/go/mise.toml",
    "stands/go/go.mod",
    "stands/python/mise.toml"
  ],
  "minimumReleaseAge": "7 days",
  "rebaseWhen": "behind-base-branch",
  "semanticCommits": "enabled",
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "schedule": [
        "every weekend"
      ],
      "automerge": true
    },
    {
      "description": "Sync Go toolchain version across go.mod and root mise.toml in one PR",
      "matchPackageNames": [
        "go"
      ],
      "matchFileNames": [
        ".config/mise.toml",
        "go.mod"
      ],
      "groupName": "go toolchain"
    },
    {
      "description": "Runtime deps of generated code — raising the lower bound drops user support, update manually",
      "matchDepTypes": [
        "dependencies"
      ],
      "matchFileNames": [
        "stands/python/pyproject.toml"
      ],
      "enabled": false
    },
    {
      "description": "Group all dev tools in root mise.toml into one PR to reduce noise",
      "matchManagers": [
        "mise"
      ],
      "matchFileNames": [
        ".config/mise.toml"
      ],
      "groupName": "dev tools",
      "matchPackageNames": [
        "!go"
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "uses: jdx/mise-action@.*\\n\\s+with:\\n\\s+version: (?<currentValue>.*)"
      ],
      "depNameTemplate": "jdx/mise",
      "datasourceTemplate": "github-releases"
    }
  ]
}
